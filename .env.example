# Cloudflare Tunnel token from Zero Trust > Networks > Tunnels
TUNNEL_TOKEN=paste-your-tunnel-token-here

# random string used to salt the hashed visitor ip on the notes api. generate
# one with: openssl rand -hex 16
IP_SALT=change-me

# optional. deploy.sh sets this from git automatically, only set it by hand
# if you build without git available
# APP_VERSION=v1.0.0
